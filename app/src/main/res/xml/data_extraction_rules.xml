<?xml version="1.0" encoding="utf-8"?>
<!-- GalaxyPods 데이터 추출 규칙 — 백업/이전 시 사용자 데이터 제외 (개인정보 보호) -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="datastore/"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="datastore/"/>
    </device-transfer>
</data-extraction-rules>
