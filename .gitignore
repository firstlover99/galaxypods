# GalaxyPods .gitignore
# Build artifacts
*.iml
.gradle/
local.properties
.idea/
.DS_Store
build/
captures/
.externalNativeBuild/
.cxx/

# Android Studio
*.jks
*.keystore
keystore.properties

# Firebase
google-services.json
firebase-credentials.json

# IDE
.vscode/
*.swp
*.swo

# Claude Code 내부 (세션 상태, 스케줄러 lock)
.claude/

# OS
Thumbs.db
ehthumbs.db
Desktop.ini

# Temporary
*.log
*.tmp
*.bak

# Test reports
**/build/reports/
**/build/test-results/

# Coverage
**/build/jacoco/

# Detekt / ktlint
.detekt-baseline.xml

# 로컬 진단 로그 덤프 (단말 PID/MAC 등 식별 정보 포함, git 커밋 X)
diagnose/
